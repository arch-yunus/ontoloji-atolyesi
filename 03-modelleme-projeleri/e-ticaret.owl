<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.example.org/ontologies/e-ticaret#"
     xml:base="http://www.example.org/ontologies/e-ticaret"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">
    <owl:Ontology rdf:about="http://www.example.org/ontologies/e-ticaret">
        <rdfs:comment xml:lang="tr">Temel bir e-ticaret hiyerarşisi (Ürün-Kategori) ontolojisi.</rdfs:comment>
    </owl:Ontology>

    <!-- Classes -->
    <owl:Class rdf:about="http://www.example.org/ontologies/e-ticaret#Kategori"/>
    <owl:Class rdf:about="http://www.example.org/ontologies/e-ticaret#Urun"/>
    
    <owl:Class rdf:about="http://www.example.org/ontologies/e-ticaret#Elektronik">
        <rdfs:subClassOf rdf:resource="http://www.example.org/ontologies/e-ticaret#Kategori"/>
    </owl:Class>
    
    <owl:Class rdf:about="http://www.example.org/ontologies/e-ticaret#Bilgisayar">
        <rdfs:subClassOf rdf:resource="http://www.example.org/ontologies/e-ticaret#Elektronik"/>
    </owl:Class>

    <!-- Properties -->
    <owl:ObjectProperty rdf:about="http://www.example.org/ontologies/e-ticaret#kategorisindedir">
        <rdfs:domain rdf:resource="http://www.example.org/ontologies/e-ticaret#Urun"/>
        <rdfs:range rdf:resource="http://www.example.org/ontologies/e-ticaret#Kategori"/>
    </owl:ObjectProperty>
    
    <owl:DatatypeProperty rdf:about="http://www.example.org/ontologies/e-ticaret#fiyat">
        <rdfs:domain rdf:resource="http://www.example.org/ontologies/e-ticaret#Urun"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    </owl:DatatypeProperty>

    <!-- Individuals -->
    <owl:NamedIndividual rdf:about="http://www.example.org/ontologies/e-ticaret#Laptop_X1">
        <rdf:type rdf:resource="http://www.example.org/ontologies/e-ticaret#Urun"/>
        <kategorisindedir rdf:resource="http://www.example.org/ontologies/e-ticaret#Bilgisayar"/>
        <fiyat rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">15000</fiyat>
    </owl:NamedIndividual>
</rdf:RDF>
