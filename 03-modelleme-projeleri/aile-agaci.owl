<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.example.org/ontologies/aile-agaci#"
     xml:base="http://www.example.org/ontologies/aile-agaci"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">
    <owl:Ontology rdf:about="http://www.example.org/ontologies/aile-agaci">
        <rdfs:comment xml:lang="tr">Basit bir aile ilişkileri ontolojisi örneği.</rdfs:comment>
    </owl:Ontology>

    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    <owl:Class rdf:about="http://www.example.org/ontologies/aile-agaci#Insan"/>
    <owl:Class rdf:about="http://www.example.org/ontologies/aile-agaci#Ebeveyn">
        <rdfs:subClassOf rdf:resource="http://www.example.org/ontologies/aile-agaci#Insan"/>
    </owl:Class>
    <owl:Class rdf:about="http://www.example.org/ontologies/aile-agaci#Cocuk">
        <rdfs:subClassOf rdf:resource="http://www.example.org/ontologies/aile-agaci#Insan"/>
    </owl:Class>

    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    <owl:ObjectProperty rdf:about="http://www.example.org/ontologies/aile-agaci#ebeveynidir">
        <owl:inverseOf rdf:resource="http://www.example.org/ontologies/aile-agaci#cocugudur"/>
        <rdfs:domain rdf:resource="http://www.example.org/ontologies/aile-agaci#Ebeveyn"/>
        <rdfs:range rdf:resource="http://www.example.org/ontologies/aile-agaci#Cocuk"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.example.org/ontologies/aile-agaci#cocugudur"/>

    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Individuals
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    <owl:NamedIndividual rdf:about="http://www.example.org/ontologies/aile-agaci#Ali">
        <rdf:type rdf:resource="http://www.example.org/ontologies/aile-agaci#Ebeveyn"/>
        <ebeveynidir rdf:resource="http://www.example.org/ontologies/aile-agaci#Veli"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://www.example.org/ontologies/aile-agaci#Veli">
        <rdf:type rdf:resource="http://www.example.org/ontologies/aile-agaci#Cocuk"/>
    </owl:NamedIndividual>
</rdf:RDF>
